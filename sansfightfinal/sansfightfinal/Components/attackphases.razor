@using sansfightfinal.Components.Models
@using sansfightfinal.Components.Services
@inject IFight Fight

<h3>AttackPhases</h3>

<div class="Attack-Phase">
    @foreach (var bone in Bones)
    {
        <BoneObstacle X="@bone.X" Y="@bone.Y" Width="@bone.Width" Height="@bone.Height"></BoneObstacle>
    }
    @foreach (var blaster in Fight.CurrentBlasters)
    {
        <BlasterObstacle X="@blaster.X" Y="@blaster.Y" Width="@blaster.Width" Height="@blaster.Height" IsCharging="@isCharging" IsFiring="@isFiring"></BlasterObstacle>
    }
</div>




@code 
{
    /// <summary>
    /// The list of bones currently active in the attack phase.
    /// </summary>
    [Parameter] public List<Bone> Bones { get; set; } = new();

    /// <summary>
    /// The timer used to move bones periodically.
    /// </summary>
    private System.Timers.Timer? movementTimer;

    /// <summary>
    /// Indicates whether the blaster is currently charging.
    /// </summary>
    private bool isCharging = true;
    /// <summary>
    /// Indicates whether the blaster is currently firing.
    /// </summary>
    private bool isFiring = true;

    public AttackPhases(IFight fight)
    {
        Fight = fight;
    }

    /// <summary>
    /// starts the timer to move bones periodically (in ms)
    /// </summary>
    protected override void OnInitialized()
    {
        movementTimer = new System.Timers.Timer(50);
        movementTimer.Elapsed += (s, e) =>
        {
            foreach (var bone in Bones)
            {
                bone.Move();
            }
            InvokeAsync(StateHasChanged);
        };
        movementTimer.Start();
    }

    /// <summary>
    /// stops and disposes the timer when the bone spawning is done
    /// </summary>
    public void Dispose()
    {
        movementTimer?.Stop();
        movementTimer?.Dispose();
    }

    /// <summary>
    /// sets charging and firing times for the blaster
    /// </summary>
    /// <returns></returns>
    protected override async Task OnInitializedAsync()
    {
        isCharging = true;
        await Task.Delay(1000); // Charging time
        isCharging = false;
        isFiring = true;
        await Task.Delay(1500); // Firing time
        isFiring = false;
    }
}
