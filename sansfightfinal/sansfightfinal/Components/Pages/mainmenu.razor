@page "/mainmenu"
@inject NavigationManager navigation
@inject IJSRuntime JS

<h3>MainMenu</h3>

<div class="MainMenu-Screen">
    <h1 class="MainMenu-Title">Sans Fight</h1>
    <p class="MainMenu-Subtitle">The Comedian stands ready for Judgement</p>

    <div class="Menu-Buttons">
        <button class="Menu-Button" @onclick="StartFight"> Start Fight</button>
        <button class="Menu-Button" @onclick="ShowInstructions">Instructions</button>
        <button class="Menu-Button" @onclick="ExitGame">DO NOT</button>
    </div>

    @if (showInstructions)
    {
        <div class="Instructions-Box">
            <h2>How To Play</h2>
            <ul>
                <li>Use WASD to move your SOUL.</li>
                <li>Avoid the bones and blasters.</li>
                <li>Survive.</li>
            </ul>
            <button class="menu-button" @onclick="HideInstructions">Back</button>
        </div>
    }
</div>


@code 
{
    /// <summary>
    /// Indicates whether the instructions are currently being shown.
    /// </summary>
    private bool showInstructions = false;

    private void StartFight()
    {
        navigation.NavigateTo("/sansfight");
    }

    /// <summary>
    /// Shows the instructions panel.
    /// </summary>
    private void ShowInstructions() => showInstructions = true;

    /// <summary>
    /// Hides the instructions panel.
    /// </summary>
    private void HideInstructions() => showInstructions = false;
    
    /// <summary>
    /// Exits the game by invoking the JavaScript close function.
    /// </summary>
    private async Task ExitGame()
    {
        await JS.InvokeVoidAsync("close");
    }
}
