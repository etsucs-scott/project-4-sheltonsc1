@page "/win"

<h3>Win</h3>

<div class="Win-Screen">
    <h1 class="Win-Title"> YOU WON!! =D</h1>
    <p class="Win-Message"> Sans has been defeated. Do you feel proud of yourself? </p>
    <button class="Restart-Fight-Button" @onclick="RestartFight">Play Again</button>
</div>

@code 
{
    [Parameter] public EventCallback OnRestart { get; set; }

    private async Task RestartFight()
    {
        if (OnRestart.HasDelegate)
        {
            await OnRestart.InvokeAsync(null);
        }
    }
}
