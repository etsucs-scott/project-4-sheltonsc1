@page "/gameover"

<h3>GameOver</h3>

<div class="GameOver-Screen">
    <h1 class="GameOver-Title">GAME OVER</h1>
    <p class="GameOver-Message"> Get up. He is waiting for you. =)</p>

    <button class="GameOver-RestartButton" @onclick="RestartFight">Try Again?</button>
</div>

@code 
{
    /// <summary>
    /// Event callback for restarting the game.
    /// </summary>
    [Parameter] public EventCallback OnRestart { get; set; }

    /// <summary>
    /// method for handling the restart button click event, invoking the OnRestart callback if it has a delegate assigned.
    /// </summary>
    /// <returns>A task representing the asynchronous operation.</returns>
    private async Task RestartFight()
    {
        if (OnRestart.HasDelegate)
        {
            await OnRestart.InvokeAsync();
        }
    }
}
